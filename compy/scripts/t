#!/usr/bin/env bash

# Credit to ThePrimeagen
# Config: ~/.bork-ai/tmux-config.yml

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
source "$SCRIPT_DIR/tmux-config-parser"

if [[ $# -eq 1 ]]; then
    selected=$1
else
    items=$(tmux_config_dirs)
    items+=$'\n'
    items+=$(tmux_config_worktrees)
    while IFS= read -r extra; do
        items+=$'\n'"$extra"
    done < <(tmux_config_extras)
    selected=$(echo "$items" | fzf)
fi

if [[ $selected == '' ]]; then
    exit
fi

if [[ "$selected" == */.claude/worktrees/* ]]; then
    worktree_name=$(basename "$selected")
    project_name=$(echo "$selected" | sed 's|/.claude/worktrees/.*||' | xargs basename)
    dirname=$(echo "${project_name}-${worktree_name}" | sed 's/\./_/g')
else
    dirname=$(basename "$selected" | sed 's/\./_/g')
fi

if [[ -n "$TMUX" ]]; then
    tmux switch-client -t ="$dirname" 2>/dev/null || \
        (tmux new-session -c "$selected" -d -s "$dirname" && tmux switch-client -t "$dirname")
else
    tmux new-session -c "$selected" -A -s "$dirname"
fi
